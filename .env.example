# ===================================================
# 基金小助手 - 环境变量示例
# 复制为各自的 .env 文件并按需修改，请勿提交真实 .env
# ===================================================

# --------------------------------------------------
# 后端（Render）- 在 Render 服务配置中设置
# --------------------------------------------------
# 允许的前端来源（逗号分隔）
# 部署 Vercel 后填入 Vercel 域名，例如：
# ALLOWED_ORIGINS=https://chicken-assistant.vercel.app,https://chicken-assistant-xxx.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Render 提供的数据持久化目录（render.yaml 已配置，通常无需手动设置）
# RENDER_DATA_DIR=/var/data

# Render 注入的监听端口（gunicorn_config.py 自动读取，无需手动设置）
# PORT=8000

# --------------------------------------------------
# 前端（Vercel）- 在 Vercel 项目设置中配置
# --------------------------------------------------
# 后端 API 地址（替换为 Render 部署后的实际地址）
VITE_API_URL=https://your-backend.onrender.com
